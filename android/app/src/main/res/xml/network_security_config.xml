<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Device linking uses WSS (TLS) with a self-signed cert generated on the Desktop.
        Cert validation is handled at the application layer via the OkHttp factory
        (ZelaraOkHttpFactory.kt), which accepts self-signed certs for local network connections.
        Authentication is enforced by the pairing token exchanged out-of-band via QR code.
        Cleartext (ws://) is no longer permitted now that WSS is in place.
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
